@using Shoopify.Models.Entities
@model Ingredient

@{
    ViewBag.Title = "Delete Ingredient";
}

<h1 class="mb-4 text-danger text-center">⚠️ Delete Ingredient</h1>

<div class="alert alert-warning text-center">
    <h4>Are you sure you want to delete this ingredient?</h4>
    <p class="mb-0"><strong>@Model.Name</strong></p>
</div>

<div class="card shadow-lg border-0 mb-4">
    <div class="card-body">
        <h5 class="card-title">Related Products</h5>

        @if (Model.ProductIngredients != null && Model.ProductIngredients.Any())
        {
            @foreach (var pi in Model.ProductIngredients)
            {
                <span class="badge bg-primary me-1">@pi.Product.Name</span>
            }
        }
        else
        {
            <p class="text-muted"><em>No related products</em></p>
        }
    </div>
</div>

<!-- الفورم الصحيح -->
<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="IngredientId" />

    <div class="d-flex justify-content-center gap-3">
        <button type="submit" class="btn btn-danger">
            🗑️ Yes, Delete
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            ⬅️ Cancel
        </a>
    </div>
</form>

@using Shoopify.Models.Entities
@model IEnumerable<Ingredient>

@{
    ViewBag.Title = "List of Restaurant Ingredients";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="fw-bold text-primary">Ingredients</h1>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Create New Ingredient
        </a>
    </div>

    <table class="table table-hover table-bordered shadow-sm rounded">
        <thead class="table-dark text-center">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Name)</th>
                <th style="width: 200px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (Ingredient i in Model)
            {
                <tr>
                    <td class="align-middle">@Html.DisplayFor(modelItem => i.Name)</td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@i.IngredientId" class="btn btn-info btn-sm me-1">
                            <i class="bi bi-eye"></i> Details
                        </a>
                        <a asp-action="Update" asp-route-id="@i.IngredientId" class="btn btn-warning btn-sm me-1">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@i.IngredientId" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

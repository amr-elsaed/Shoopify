@using Shoopify.Models.Entities
@model Ingredient

@{
    ViewBag.Title = "Edit Ingredient";
}

<h1 class="mb-4 text-primary text-center">✏️ Edit Ingredient</h1>

<div class="card shadow-lg border-0 mb-4">
    <div class="card-body">
        <form asp-action="Update" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IngredientId" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <h5 class="card-title">Related Products</h5>
                @if (Model.ProductIngredients != null && Model.ProductIngredients.Any())
                {
                    @foreach (var pi in Model.ProductIngredients)
                    {
                        <span class="badge bg-primary me-1">@pi.Product.Name</span>
                    }
                }
                else
                {
                    <p class="text-muted"><em>No related products</em></p>
                }
            </div>

            <div class="d-flex justify-content-center gap-3">
                <button type="submit" class="btn btn-primary">💾 Save</button>
                <a asp-action="Index" class="btn btn-secondary">⬅️ Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@model IEnumerable<Shoopify.Models.Entities.Product>

@{
    ViewBag.Title = "Products & Orders";
}

<h1 class="mb-4 text-center">📦 Products and their Orders</h1>

<div class="d-flex justify-content-between mb-4">
    <a asp-action="Create" class="btn btn-success">➕ Add New Product</a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var product in Model)
    {
        <div class="col">
            <div class="card shadow-lg border-0 h-100">
                <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" />

                <div class="card-body">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text">@product.Description</p>
                    <p><span class="text-success fw-bold">💲 @product.Price</span></p>
                    <p><span class="badge bg-info">Stock: @product.Stock</span></p>

                    @if (product.OrderItems != null && product.OrderItems.Any())
                    {
                        <h6 class="mt-3">Orders:</h6>
                        <ul class="list-group list-group-flush">
                            @foreach (var oi in product.OrderItems)
                            {
                                <li class="list-group-item">
                                    Order #@oi.OrderId - Qty: @oi.Quantity - 💲 @oi.Price <br />
                                    <small class="text-muted">Date: @oi.Order.OrderDate.ToShortDateString()</small>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted"><em>No orders yet</em></p>
                    }
                </div>

                <div class="card-footer d-flex justify-content-between">
                    <a asp-action="Edit" asp-route-id="@product.ProductId" class="btn btn-sm btn-warning">✏️ Edit</a>
                    <a asp-action="Delete" asp-route-id="@product.ProductId" class="btn btn-sm btn-danger">🗑️ Delete</a>
                </div>
            </div>
        </div>
    }
</div>

@model Shoopify.Models.Entities.Product

@{
    ViewBag.Title = "Delete Product";
}

<h1 class="text-danger text-center mb-4">🛑 Delete Product</h1>

<div class="card shadow-lg border-0 mb-4">
    <div class="card-body">
        <h5 class="card-title">Are you sure you want to delete this product?</h5>

        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.Price</dd>

            <dt class="col-sm-3">Stock</dt>
            <dd class="col-sm-9">@Model.Stock</dd>

            <dt class="col-sm-3">Image</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" width="150" class="rounded shadow-sm" />
                }
                else
                {
                    <p class="text-muted"><em>No image available</em></p>
                }
            </dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProductId" />

            <div class="d-flex justify-content-center gap-3">
                <button type="submit" class="btn btn-danger">🗑️ Delete</button>
                <a asp-action="Index" class="btn btn-secondary">⬅️ Cancel</a>
            </div>
        </form>
    </div>
</div>
